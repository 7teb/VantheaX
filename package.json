{
  "name": "vantheax",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "start": "electron .",
    "package": "npm.cmd run build && electron-builder --win dir",
    "dist": "npm.cmd run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "dev.local.vantheax",
    "productName": "VantheaX",
    "directories": {
      "output": "outputs/electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.ico"
    },
    "asar": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  }
}
